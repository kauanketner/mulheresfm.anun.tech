REPO_URL=https://github.com/kauanketner/mulheresfm.anun.tech.git
BRANCH=main
APP_PORT=3000
HEALTH_PATH=/health
DATABASE_URL=file:/data/app.db

# Variáveis da aplicação (passadas ao container)
ADMIN_PASSWORD=troque-esta-senha
DATA_DIR=/data
